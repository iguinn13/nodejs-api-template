{
  "compilerOptions": {
    "target": "es2020",                      
    "experimentalDecorators": true,       
    "emitDecoratorMetadata": true,        
    "module": "commonjs",                    
    "rootDir": "./src",                      
    "outDir": "./build",                       
    "esModuleInterop": true,                 
    "forceConsistentCasingInFileNames": true,
    "strict": true,                          
    "noImplicitAny": false,                
    "skipLibCheck": true                     
  }
}
